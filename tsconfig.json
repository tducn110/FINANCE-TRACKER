{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@client/*": ["client/src/*"],
      "@server/*": ["server/src/*"]
    },
    "types": ["node"]
  },
  "include": [
    "server/src/**/*", 
    "client/src/**/*", 
    "server/drizzle.config.ts"
  ],
  "exclude": ["node_modules", "**/dist"]
}
